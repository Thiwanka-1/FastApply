{
  "manifest_version": 3,
  "name": "FastApply AI",
  "version": "1.0.0",
  "description": "Smart job application autofill engine.",
  "action": {
    "default_title": "FastApply Quick Access",
    "default_popup": "popup.html"
  },
  "options_page": "index.html",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.lever.co/*"
      ],
      "js": ["utils.js", "lever.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://*.greenhouse.io/*",
        "https://boards.greenhouse.io/*"
      ],
      "js": ["utils.js", "greenhouse.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://jobs.ashbyhq.com/*",
        "https://*.ashbyhq.com/*"
      ],
      "js": ["utils.js", "ashby.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "clipboardWrite",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "http://localhost:5173/*",
    "<all_urls>"
  ]
}